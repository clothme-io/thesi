# Database — clothme-db Postgres (:5434), database name: thesi
# Start: cd ../clothme-db && docker compose up -d postgres
# Migrate: cd ../clothme-db && ./scripts/migrate.sh thesi
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/thesi
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=thesi
POSTGRES_SSL_ENABLED=false

# Docker Compose (thesi-api container) uses host.docker.internal:5434
# DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5434/thesi

# Server
PORT=5000
NODE_ENV=development

# Auth
# Required. Use distinct high-entropy values in each environment.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
THESI_WEB_URL=http://localhost:3010

# Email — Resend (primary) or AWS SES (fallback)
RESEND_API_KEY=
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EMAIL_FROM=Thesi <noreply@thesi.clothme.io>

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin
# Required while creator approval endpoints are enabled.
ADMIN_API_KEY=
