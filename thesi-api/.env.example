# Database — clothme-db Postgres (:5434), database name: thesi
# Start: cd ../clothme-db && docker compose up -d postgres
# Migrate: cd ../clothme-db && ./scripts/migrate.sh thesi
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/thesi
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=thesi
POSTGRES_SSL_ENABLED=false

# Docker Compose (thesi-api container) uses host.docker.internal:5434
# DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5434/thesi

# Server
PORT=5010
NODE_ENV=development

# Auth
# Development-only defaults. Replace with distinct high-entropy values elsewhere.
JWT_SECRET=thesi-local-jwt-secret-change-before-production
JWT_REFRESH_SECRET=thesi-local-refresh-secret-change-before-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
THESI_WEB_URL=http://localhost:3010
# When true (default): new creators must change temp password on first login.
# When false: skip forced password change / onboarding gate (faster local testing).
AUTH_FORCE_PASSWORD_CHANGE=true

# Email — Resend (primary) or AWS SES (fallback)
RESEND_API_KEY=
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EMAIL_FROM=Thesi <noreply@thesi.clothme.io>

# Novu — invite workflow triggers (optional in local; logs when unset)
NOVU_API_KEY=
NOVU_API_URL=https://api.novu.co
NOVU_CAMPAIGN_INVITE_WORKFLOW_ID=campaign-invite
NOVU_PLATFORM_BRAND_INVITE_WORKFLOW_ID=platform-invite-brand

# Stripe — brand billing (optional in local; persists profile without sync when unset)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Stripe CLI / Dashboard endpoint secret for POST /v1/stripe/webhooks
# When unset, the API accepts unsigned JSON events (local/E2E only).
STRIPE_WEBHOOK_SECRET=

# Admin
# Development-only default. Replace outside local development.
ADMIN_API_KEY=thesi-local-admin-key-change-before-production

# File storage — local by default; set Bunny vars to use CDN
FILE_STORAGE_DIR=./.data/uploads
BUNNY_API_KEY=
BUNNY_STORAGE_REGION=
BUNNY_THESI_STORAGE_ZONE_NAME=
BUNNY_THESI_PULL_ZONE=
