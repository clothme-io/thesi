# Database — host development (run API/migrations on your machine)
# Requires: docker compose up postgres -d  (from thesi/ root)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/thesi
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=thesi
POSTGRES_SSL_ENABLED=false

# Docker Compose overrides these inside the thesi-api container:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/thesi
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432

# Server
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Email — Resend (primary) or AWS SES (fallback)
RESEND_API_KEY=
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EMAIL_FROM=Thesi <noreply@thesi.clothme.io>

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin
ADMIN_API_KEY=
