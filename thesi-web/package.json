{
  "name": "thesi-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "dev:clean": "pkill -f 'next dev.*thesi-web' 2>/dev/null || true; lsof -ti :3000,:3001 | xargs kill -9 2>/dev/null || true; rm -rf .next && next dev --turbopack -p 3000",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "next": "15.5.20"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "@eslint/eslintrc": "^3"
  }
}
